{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>jfebgp/renovate-config"
  ],
  "configMigration": true,
  "automergeType": "pr",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "automerge": true
  },
  "osvVulnerabilityAlerts": true,
  "minimumReleaseAge": "3 days",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^tool-versions\\.txt$/"
      ],
      "matchStrings": ["helm=(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "helm",
      "packageNameTemplate": "helm/helm",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^tool-versions\\.txt$/"
      ],
      "matchStrings": ["node=(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "nodejs/node",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^deployment/deployment\\.yaml$/"
      ],
      "matchStrings": ["image:\\s+(?<depName>[^\\s:]+):(?<currentValue>[^\\s]+)"],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "groupName": "@types packages",
      "automerge": true,
      "matchPackageNames": [
        "/^@types//"
      ]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "prPriority": 3
    },
    {
      "matchPackageNames": ["helm", "helm/helm"],
      "versioning": "semver"
    },
    {
      "matchCategories": ["security"],
      "automerge": true,
      "automergeType": "pr",
      "prPriority": 10
    }
  ]
}
